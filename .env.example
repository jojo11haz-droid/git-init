# Copy to .env and fill in. Never commit the real .env.

# Anthropic API key for server-side check-in summarization.
ANTHROPIC_API_KEY=

# Postgres connection string (Neon/Supabase/Render all provide one).
# Check-ins, patients, and clinician accounts persist here.
DATABASE_URL=

# Set to "disable" only for a local Postgres without SSL (e.g. localhost dev).
# Leave unset for hosted providers.
# DATABASE_SSL=disable

# Optional: email delivery via Resend (resend.com) — used for clinician
# password-reset links and risk-alert notifications. Without it, emails are
# printed to the server logs instead of being sent.
# RESEND_API_KEY=
# EMAIL_FROM=Between <onboarding@resend.dev>
